{
  "dictionaries": [
    "nvim-spell"
  ],
  "language": "en",
  "dictionaryDefinitions": [
    {
      "name": "nvim-spell",
      "path": "./spell/en.utf-8.add",
      "addWords": true
    }
  ],
  // Skip identifiers that are almost never English prose.
  "ignoreRegExpList": [
    "/\\b[A-Z]{2,}\\b/g", // ALL CAPS acronyms: IBM, PII, GDPR
    "/\\b[a-z][a-z0-9]*[A-Z][a-zA-Z0-9]*\\b/g", // camelCase: privacyObj, ucdeOrgTenantId
    "/\\b[A-Z][a-z0-9]+[A-Z][a-zA-Z0-9]*\\b/g" // PascalCase: TenantId, PrivacyContextService (not "Hello")
  ],
  "words": [
    "retrobridge",
    "retrobridges",
    "api",
    "apis",
    "Onecloud",
    "Oneclouds",
    "ucde",
    "ucdes",
    "Splunk",
    "Splunks",
    "associated",
    "associateds",
    "Tenantid",
    "Tenantids",
    "idpid",
    "idpids",
    "jsonschema",
    "jsonschemas",
    "hpid",
    "hpids",
    "agentic",
    "agentics"
  ],
  "version": "0.2"
}
